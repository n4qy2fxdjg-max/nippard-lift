{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lift",
  "main": "src/worker.ts",
  "compatibility_date": "2025-11-01",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lift-db",
      "database_id": "0e9ba5ee-3a1a-4492-8df6-cdafb1763d34"
    }
  ]
}
